{
  "ConnectionStrings": {
    "souschef": "Host=localhost;Port=5432;Database=souschef;Username=souschef;Password=souschef"
  },
  "Storage": {
    "BucketName": "souschef",
    "ServiceUrl": "http://localhost:9000",
    "Region": "us-east-1"
  },
  "Extraction": {
    "Provider": "Anthropic",
    "ModelName": "claude-sonnet-4-6",
    "Endpoint": "https://api.anthropic.com"
  },
  "Embedding": {
    "Provider": "OpenAI",
    "ModelName": "text-embedding-3-small",
    "Dimensions": 1536,
    "Endpoint": "https://api.openai.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
